# M1L4 Activity 3: Natural Numbers Sum

# Take the value of n from the user
n = int(input("Enter a positive number: "))

# Initialize the sum
total = 0

# Find the sum of natural numbers from 1 to n
for i in range(1, n + 1):
    total += i

# Display the result
print("The sum of the first", n, "natural numbers is", total)
