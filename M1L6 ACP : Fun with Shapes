# M1L6 ACP: Fun with Shapes

import turtle

# Create a turtle object
pen = turtle.Turtle()

# Set drawing speed
pen.speed(5)

# Draw a square
for i in range(4):
    pen.forward(100)
    pen.right(90)

# Move to a new position
pen.penup()
pen.goto(150, 0)
pen.pendown()

# Draw a triangle
for i in range(3):
    pen.forward(100)
    pen.left(120)

# Move to another position
pen.penup()
pen.goto(-150, 0)
pen.pendown()

# Draw a circle
pen.circle(50)

# Keep the window open
turtle.done()
