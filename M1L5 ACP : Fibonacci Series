# Define a function to print Fibonacci series
def fibonacci(n):
    a = 0
    b = 1

    print("Fibonacci Series:")

    for i in range(n):
        print(a, end=" ")
        c = a + b
        a = b
        b = c

# Take input from the user
terms = int(input("Enter the number of terms: "))

# Call the function
fibonacci(terms)
